# Backend
PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database
DB_URL=jdbc:mysql://localhost:3306/gurukrupa_pools?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
DB_USERNAME=root
DB_PASSWORD=your_database_password
DB_DRIVER=com.mysql.cj.jdbc.Driver
JPA_DDL_AUTO=update
SQL_INIT_MODE=never

# Website domain allowed to call backend
CORS_ALLOWED_ORIGIN_PATTERNS=https://yourdomain.com,https://www.yourdomain.com

# Secret token required for admin-only inquiry list/status APIs.
# Keep this private. Public customer enquiry submissions do not use this token.
ADMIN_API_TOKEN=replace_with_a_long_random_secret

# Admin email notifications
ADMIN_EMAIL=admin@yourdomain.com
MAIL_FROM=no-reply@yourdomain.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@yourdomain.com
MAIL_PASSWORD=your_email_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
